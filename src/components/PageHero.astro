---
interface Crumb { label: string; href: string }
interface Props { eyebrow: string; title: string; lead?: string; crumbs?: Crumb[] }
const { eyebrow, title, lead, crumbs = [] } = Astro.props;
---
<section class="relative overflow-hidden bg-green text-cream pt-32 sm:pt-36">
  <div class="absolute inset-0 dot-grid opacity-[0.06]" aria-hidden="true"></div>
  <div class="absolute -right-20 -top-10 h-72 w-72 rounded-full bg-brass/12 blur-3xl" aria-hidden="true"></div>
  <div class="mx-auto max-w-[80rem] px-4 sm:px-6 pb-16 sm:pb-20 relative">
    {crumbs.length > 0 && (
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex flex-wrap items-center gap-2 text-[0.8rem] text-cream/55">
          {crumbs.map((c, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && <span aria-hidden="true">/</span>}
              <a href={c.href} class="hover:text-cream transition-colors">{c.label}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}
    <p class="eyebrow text-brass-soft">{eyebrow}</p>
    <h1 class="font-display text-[2.6rem] sm:text-6xl xl:text-7xl leading-[1.04] tracking-tight mt-4 max-w-4xl" set:html={title} />
    {lead && <p class="mt-6 text-lg text-cream/75 leading-relaxed max-w-2xl">{lead}</p>}
  </div>
</section>
