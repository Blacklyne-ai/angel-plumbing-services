---
import { business } from "../data/site";
import EnquiryForm from "./EnquiryForm.astro";
interface Props { heading?: string }
const { heading = "Tell us about your property" } = Astro.props;
---
<section id="contact" class="bg-paper scroll-mt-24">
  <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
    <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-12 lg:gap-16">
      <div>
        <span class="eyebrow text-brass-deep">Get in touch</span>
        <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">{heading}</h2>
        <p class="mt-4 text-ink-soft leading-relaxed max-w-md">
          Booking a site visit, chasing a quote or dealing with an emergency - reach us however
          suits. We cover Islington, Clerkenwell and across North London.
        </p>

        <div class="mt-8 space-y-4">
          <a href={`tel:${business.phoneHref}`} class="flex items-start gap-4 group">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-green text-cream shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2Z"/></svg>
            </span>
            <span>
              <span class="block text-[0.78rem] font-semibold uppercase tracking-wider text-ink-soft">Call us</span>
              <span class="block font-display text-xl text-green group-hover:text-brass-deep transition-colors">{business.phoneDisplay}</span>
            </span>
          </a>
          <a href={`mailto:${business.email}`} class="flex items-start gap-4 group">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-green text-cream shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="m3 8 9 5 9-5"/></svg>
            </span>
            <span>
              <span class="block text-[0.78rem] font-semibold uppercase tracking-wider text-ink-soft">Email</span>
              <span class="block font-display text-xl text-green group-hover:text-brass-deep transition-colors break-all">{business.email}</span>
            </span>
          </a>
          <div class="flex items-start gap-4">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-green text-cream shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <span>
              <span class="block text-[0.78rem] font-semibold uppercase tracking-wider text-ink-soft">Find us</span>
              <span class="block text-ink not-italic">{business.address.line1}, {business.address.line2}, {business.address.city} {business.address.postcode}</span>
              <span class="block text-[0.82rem] text-ink-soft mt-0.5">{business.hours}</span>
            </span>
          </div>
        </div>

        <div class="mt-8 overflow-hidden rounded-3xl border border-line">
          <iframe
            title="Map showing Angel Plumbing Services, 177 Goswell Road, Clerkenwell"
            src={business.mapsEmbed}
            width="100%" height="240" style="border:0" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>

      <div class="rounded-[2rem] border border-line bg-cream/50 p-6 sm:p-9">
        <EnquiryForm />
      </div>
    </div>
  </div>
</section>
