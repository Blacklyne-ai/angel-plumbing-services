---
import Wordmark from "./Wordmark.astro";
import { business, nav } from "../data/site";
---
<header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-300">
  <div class="mx-auto max-w-[80rem] px-4 sm:px-6">
    <div
      id="header-bar"
      class="mt-3 flex items-center justify-between gap-4 rounded-full border border-line/70 bg-paper/80 px-4 sm:px-5 py-2.5 backdrop-blur-md transition-all duration-300"
    >
      <Wordmark />

      <nav aria-label="Primary" class="hidden lg:flex items-center gap-1">
        {nav.map((item) => (
          <a
            href={item.href}
            class="rounded-full px-3 py-2 text-[0.9rem] font-medium text-ink-soft hover:text-green hover:bg-green/5 transition-colors"
          >{item.label}</a>
        ))}
      </nav>

      <div class="flex items-center gap-2">
        <span class="hidden xl:inline-flex items-center gap-1.5 rounded-full bg-green/8 px-3 py-1.5 text-[0.72rem] font-semibold text-green">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brass opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brass"></span>
          </span>
          24-hr emergency
        </span>
        <a href={`tel:${business.phoneHref}`} class="hidden sm:inline-flex btn btn-ghost !px-4 !py-2.5 text-[0.85rem]">
          {business.phoneDisplay}
        </a>
        <a href="/contact" class="btn btn-primary !px-4 !py-2.5 text-[0.85rem]">Book a site visit</a>

        <button
          id="menu-toggle"
          class="lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-full border border-line text-green"
          aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden mx-4 mt-2 rounded-3xl border border-line bg-paper shadow-lift overflow-hidden">
    <nav aria-label="Mobile" class="flex flex-col p-2">
      {nav.map((item) => (
        <a href={item.href} class="rounded-2xl px-4 py-3 text-[1.05rem] font-medium text-ink hover:bg-green/5">{item.label}</a>
      ))}
      <div class="mt-1 grid grid-cols-2 gap-2 p-2">
        <a href={`tel:${business.phoneHref}`} class="btn btn-ghost">Call us</a>
        <a href="/contact" class="btn btn-primary">Book</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const bar = document.getElementById("header-bar");
  const onScroll = () => {
    if (window.scrollY > 16) bar?.classList.add("shadow-soft", "!bg-paper/95");
    else bar?.classList.remove("shadow-soft", "!bg-paper/95");
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => { menu.classList.add("hidden"); toggle?.setAttribute("aria-expanded", "false"); })
  );
</script>
