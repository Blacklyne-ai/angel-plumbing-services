---
import { business } from "../data/site";
---
<div
  id="floating-cta"
  class="fixed bottom-4 right-4 z-50 flex flex-col items-end gap-2.5 opacity-0 translate-y-3 pointer-events-none transition-all duration-300"
>
  <a
    href="/contact"
    class="inline-flex items-center gap-2 rounded-full bg-green px-4 py-3 text-[0.85rem] font-semibold text-cream shadow-lift hover:bg-green-deep transition-colors"
  >
    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <rect x="3" y="4" width="18" height="16" rx="2"/><path d="m3 8 9 5 9-5"/>
    </svg>
    Book a site visit
  </a>
  <a
    href={`tel:${business.phoneHref}`}
    class="inline-flex items-center gap-2 rounded-full bg-brass px-4 py-3 text-[0.85rem] font-semibold text-white shadow-lift hover:bg-brass-deep transition-colors"
    aria-label={`Call Angel Plumbing on ${business.phoneDisplay}`}
  >
    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2Z"/>
    </svg>
    <span class="sm:hidden">Call</span><span class="hidden sm:inline">{business.phoneDisplay}</span>
  </a>
</div>

<script>
  const el = document.getElementById("floating-cta");
  const onScroll = () => {
    if (window.scrollY > 200) el?.classList.remove("opacity-0", "translate-y-3", "pointer-events-none");
    else el?.classList.add("opacity-0", "translate-y-3", "pointer-events-none");
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
