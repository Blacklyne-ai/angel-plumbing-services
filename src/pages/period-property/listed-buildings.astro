---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import ClosingCTA from "../../components/ClosingCTA.astro";
import ContactSection from "../../components/ContactSection.astro";

const principles = [
  ["Consent isn't always needed", "Upgrading plumbing in a listed building often needs no consent - provided historic fabric isn't damaged or obscured. We assess this honestly rather than over-cautiously."],
  ["Cutting fabric triggers consent", "Chasing pipework into original plaster, stone or beams, or altering anything externally visible, usually needs listed-building consent. We flag it before work starts."],
  ["Reversible interventions", "We fit services so they can be removed later without harming the building, keeping pipe runs accessible - the principle conservation officers look for."],
  ["Facade-visible work", "Front soil stacks, hoppers and downpipes on a listed terrace or in a conservation area are scrutinised. Cast-iron-look or painted replacements preserve the appearance."],
];
---
<Base
  title="Listed Building Plumbing - Consent & Conservation in Islington"
  description="Plumbing work in listed buildings and conservation areas across Islington and Clerkenwell. We work to the reversible-intervention principle, flag where listed-building consent is needed, and preserve facade-visible features. Family-run since the 1980s."
  path="/period-property/listed-buildings"
>
  <PageHero
    eyebrow="Period property"
    title="Listed buildings,<br /><span class='italic font-bold'>handled with care.</span>"
    lead="Much of Islington and Clerkenwell is listed or within a conservation area. We plumb these homes the way they deserve - sympathetically, reversibly, and with consent navigated properly."
    crumbs={[
      { label: "Home", href: "/" },
      { label: "Period property", href: "/period-property" },
      { label: "Listed buildings", href: "/period-property/listed-buildings" },
    ]}
  />

  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-24">
      <div class="max-w-3xl reveal">
        <p class="font-display text-2xl sm:text-3xl text-green leading-snug">
          Listed-building consent exists to protect what makes a building special. Carrying out works
          that need consent without it is a criminal offence - and unlike ordinary planning breaches,
          it never becomes immune with time.
        </p>
        <p class="mt-6 text-ink-soft leading-relaxed">
          That sounds daunting. In practice, sensible plumbing work in a listed home is entirely
          possible - it just needs a contractor who understands where the lines are. We've spent forty
          years working in exactly these streets, and we'd rather have the conversation about consent
          early than discover a problem halfway through.
        </p>
      </div>

      <div class="mt-14 grid sm:grid-cols-2 gap-5">
        {principles.map(([t, b], i) => (
          <div class="reveal rounded-3xl border border-line bg-paper p-7">
            <span class="font-display text-3xl text-brass">{String(i + 1).padStart(2, "0")}</span>
            <h2 class="font-display text-2xl text-green mt-3">{t}</h2>
            <p class="mt-3 text-ink-soft leading-relaxed">{b}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 reveal rounded-3xl border border-brass/30 bg-brass/8 p-7 max-w-3xl">
        <p class="eyebrow text-brass-deep">Good to know</p>
        <p class="mt-3 text-ink-soft leading-relaxed">
          Conservation officers are generally supportive of work that maintains a building's character,
          and most councils offer free pre-application advice. Where a project calls for it, we'll help
          you take that route before committing to anything.
        </p>
      </div>
    </div>
  </section>

  <ClosingCTA heading="Got a listed home in Islington?" />
  <ContactSection />
</Base>
