---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import ClosingCTA from "../components/ClosingCTA.astro";
import ContactSection from "../components/ContactSection.astro";
import { reviews, business } from "../data/site";
---
<Base
  title="Reviews - Angel Plumbing Services, Rated 8.7/10"
  description="Verified customer reviews of Angel Plumbing Services, rated 8.7/10 from 60 Checkatrade reviews. Read what Islington and Clerkenwell homeowners say about our period-property plumbing and heating work."
  path="/reviews"
>
  <PageHero
    eyebrow="In their words"
    title="Rated 8.7/10<br /><span class='italic font-bold'>by Islington.</span>"
    lead="From 60 verified Checkatrade reviews. Here are a few in full - real customers, real jobs, across EC1 and the surrounding postcodes."
    crumbs={[{ label: "Home", href: "/" }, { label: "Reviews", href: "/reviews" }]}
  />

  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-24">
      <div class="grid lg:grid-cols-3 gap-5">
        {reviews.map((r) => (
          <figure class="reveal flex flex-col rounded-3xl border border-line bg-paper p-7">
            <div class="flex items-center justify-between">
              <div class="flex gap-0.5 text-brass" aria-label={`${r.rating} out of 10`}>
                {Array.from({ length: 5 }).map(() => (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 3 6.9 7.5.6-5.7 4.9 1.8 7.3L12 17.8 5.1 21.7l1.8-7.3L1.2 9.5 8.7 8.9 12 2Z"/></svg>
                ))}
              </div>
              <span class="text-[0.72rem] font-semibold uppercase tracking-wider text-ink-soft">{r.date}</span>
            </div>
            <blockquote class="mt-4 text-ink-soft leading-relaxed flex-1 text-[0.95rem]">"{r.text}"</blockquote>
            <figcaption class="mt-5 pt-5 border-t border-line flex items-center justify-between">
              <span class="font-semibold text-ink">{r.name} <span class="text-ink-soft font-normal">· {r.place}</span></span>
              <span class="text-[0.76rem] text-brass-deep font-medium">{r.source}</span>
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="mt-12 reveal rounded-3xl border border-line bg-cream-deep p-8 text-center max-w-2xl mx-auto">
        <p class="font-display text-5xl text-green">{business.reviewRating}</p>
        <p class="mt-2 text-ink-soft">Average across {business.reviewCount} verified Checkatrade reviews</p>
        <p class="mt-4 text-[0.9rem] text-ink-soft/80">
          We'd rather show you a few real reviews in full than a wall of star ratings. If you've worked
          with us, a review on Checkatrade helps the next Islington homeowner find a plumber they can trust.
        </p>
      </div>
    </div>
  </section>

  <ClosingCTA />
  <ContactSection />
</Base>
