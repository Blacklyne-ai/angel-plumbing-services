---
import Base from "../layouts/Base.astro";
import TerraceFacade from "../components/art/TerraceFacade.astro";
import PeriodWizard from "../components/PeriodWizard.astro";
import TrustStrip from "../components/TrustStrip.astro";
import Marquee from "../components/Marquee.astro";
import Cp12Tool from "../components/Cp12Tool.astro";
import ClosingCTA from "../components/ClosingCTA.astro";
import ContactSection from "../components/ContactSection.astro";
import {
  business, serviceHubs, eras, areas, buyerTypes, reasons, timeline, reviews,
} from "../data/site";

const hubEras = eras.filter((e) => e.inHub);
const primaryAreas = areas.filter((a) => a.primary);
const marqueeItems = [
  "Islington", "Clerkenwell", "Highbury", "Canonbury", "Barnsbury", "Angel",
  "Holloway", "Finsbury", "King's Cross", "Hackney", "Camden", "Period property specialists",
];
const hubIcon: Record<string, string> = {
  plumbing: `<path d="M8 21h8M12 21v-6M5 4h6v4a3 3 0 0 1-6 0V4Z"/><path d="M11 6h4a4 4 0 0 1 4 4v2"/>`,
  heating: `<path d="M12 3c0 4-5 5-5 9a5 5 0 0 0 10 0c0-2-1-3-2-4 .2 2-1 3-2 3 .5-3-1-6-1-8Z"/>`,
  "gas-safety": `<path d="M12 3 5 6v5c0 4 3 7 7 9 4-2 7-5 7-9V6l-7-3Z"/><path d="m9 12 2 2 4-4"/>`,
};
---
<Base
  title="Period-Property Plumbers in Islington & Clerkenwell"
  description="Angel Plumbing Services - family-run plumbing & heating in Islington and Clerkenwell since the 1980s. Period-property specialists, Gas Safe registered, APHC members. 24-hour emergency. Call 020 7251 3418."
  path="/"
>
  <!-- HERO -->
  <section class="relative overflow-hidden mesh-cream grain pt-28 sm:pt-32 pb-20 sm:pb-28">
    <div class="absolute inset-0 blueprint opacity-50" data-parallax="0.06" aria-hidden="true"></div>
    <!-- floating decorative parallax elements -->
    <div class="absolute right-[10%] top-[16%] h-44 w-44 rounded-full border border-brass/25 floaty hidden sm:block" data-parallax="0.14" aria-hidden="true"></div>
    <div class="absolute left-[4%] bottom-[12%] h-28 w-28 rounded-full bg-brass/10 blur-2xl floaty" data-parallax="0.22" aria-hidden="true"></div>
    <div class="absolute right-[28%] bottom-[8%] h-3 w-3 rounded-full bg-brass/60 floaty hidden lg:block" data-parallax="0.3" aria-hidden="true"></div>

    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 relative z-10">
      <div class="grid lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-10 items-center">
        <div>
          <p class="reveal inline-flex items-center gap-2.5 rounded-full glass px-4 py-2 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-green">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brass opacity-70"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-brass"></span>
            </span>
            Clerkenwell · Est. 1980s · Gas Safe
          </p>

          <h1 class="font-display text-[2.7rem] sm:text-6xl xl:text-[5.2rem] text-green leading-[1.0] tracking-tight mt-6">
            <span class="block reveal" data-delay="60">Period-property</span>
            <span class="block reveal" data-delay="140">plumbing,<span class="text-gold"> family-run.</span></span>
            <span class="block italic font-bold reveal mt-1.5" data-delay="240">Islington since<br class="sm:hidden" /> the 1980s.</span>
          </h1>

          <p class="mt-7 text-lg text-ink-soft leading-relaxed max-w-xl reveal" data-delay="340">
            Forty years on Goswell Road, looking after the Georgian and Victorian homes that surround
            us. Done with respect for the building they sit in - and a 24-hour line when it can't wait.
          </p>

          <div class="mt-9 flex flex-wrap gap-3 reveal" data-delay="420">
            <a href="#wizard" class="btn btn-primary" data-magnetic="0.25">Find your property's plumbing</a>
            <a href={`tel:${business.phoneHref}`} class="btn btn-ghost" data-magnetic="0.25">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2Z"/></svg>
              {business.phoneDisplay}
            </a>
          </div>

          <div class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-3 reveal" data-delay="500">
            <div class="flex items-center gap-2">
              <div class="flex gap-0.5 text-brass">
                {Array.from({ length: 5 }).map(() => (<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 3 6.9 7.5.6-5.7 4.9 1.8 7.3L12 17.8 5.1 21.7l1.8-7.3L1.2 9.5 8.7 8.9 12 2Z"/></svg>))}
              </div>
              <span class="text-[0.85rem] text-ink-soft"><strong class="text-ink">8.7/10</strong> · 60 reviews</span>
            </div>
            <span class="h-4 w-px bg-line hidden sm:block"></span>
            <span class="text-[0.85rem] text-ink-soft">APHC member · Fully insured</span>
          </div>
        </div>

        <!-- layered scene -->
        <div class="relative" data-reveal="scale" data-delay="200">
          <div class="relative mx-auto max-w-[26rem] lg:max-w-none" data-parallax="-0.05">
            <div data-tilt="5" class="relative aspect-[3/4] overflow-hidden rounded-[2.5rem] ring-line shadow-float bg-cream-deep">
              <TerraceFacade class="absolute inset-0 h-full w-full" />
              <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-green-deep/70 to-transparent"></div>
              <div class="absolute left-5 bottom-5 text-cream tilt-inner">
                <p class="font-display text-3xl leading-none">Goswell Road</p>
                <p class="eyebrow text-brass-soft mt-1.5">177 · Clerkenwell EC1</p>
              </div>
            </div>

            <!-- floating glass chips -->
            <div class="absolute -left-4 sm:-left-8 top-10 glass rounded-2xl px-5 py-3.5 floaty" data-parallax="0.16">
              <p class="font-display text-3xl text-green leading-none"><span data-count="40">40</span></p>
              <p class="text-[0.7rem] font-semibold uppercase tracking-wider text-brass-deep mt-1">Years in Islington</p>
            </div>
            <div class="absolute -right-3 sm:-right-7 top-1/3 glass rounded-2xl px-4 py-3 floaty flex items-center gap-2.5" data-parallax="0.24" style="animation-delay:1.5s">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-green/10 text-green">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 3 5 6v5c0 4 3 7 7 9 4-2 7-5 7-9V6l-7-3Z"/><path d="m9 12 2 2 4-4"/></svg>
              </span>
              <span class="leading-tight">
                <span class="block text-[0.82rem] font-semibold text-ink">Gas Safe</span>
                <span class="block text-[0.68rem] text-ink-soft">Registered</span>
              </span>
            </div>
            <div class="absolute -right-2 sm:-right-6 -bottom-4 glass rounded-2xl px-4 py-3 max-w-[13rem] floaty" data-parallax="0.12" style="animation-delay:0.8s">
              <p class="text-[0.8rem] text-ink-soft leading-snug italic">"Half the price British Gas quoted."</p>
              <p class="text-[0.68rem] font-semibold text-brass-deep mt-1.5">Checkatrade · EC1V</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT BAND -->
  <section class="relative mesh-green grain text-cream overflow-hidden">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-12 relative z-10">
      <dl class="grid grid-cols-2 lg:grid-cols-4 gap-y-8 gap-x-4" data-stagger>
        {[
          { v: "40", suf: "", l: "Years family-run in Islington", count: true },
          { v: "8.7", suf: "", l: "Rated on Checkatrade", count: false },
          { v: "60", suf: "+", l: "Verified customer reviews", count: true },
          { v: "24", suf: "/7", l: "Emergency cover, North London", count: false },
        ].map((s) => (
          <div class="text-center lg:text-left lg:px-3 lg:border-l lg:border-cream/15 lg:first:border-0">
            <dt class="font-display text-5xl sm:text-6xl text-cream leading-none">
              {s.count ? <span data-count={s.v} data-suffix={s.suf}>{s.v}{s.suf}</span> : <span>{s.v}<span class="text-brass-soft">{s.suf}</span></span>}
            </dt>
            <dd class="text-[0.82rem] text-cream/60 mt-2.5">{s.l}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <TrustStrip />

  <!-- WIZARD -->
  <section class="relative mesh-cream overflow-hidden">
    <div class="absolute left-[-8%] top-1/4 h-72 w-72 rounded-full bg-green/5 blur-3xl" data-parallax="0.1" aria-hidden="true"></div>
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-24 relative">
      <div data-reveal="scale">
        <PeriodWizard />
      </div>
    </div>
  </section>

  <!-- FOUR GOOD REASONS -->
  <section class="relative mesh-cream overflow-hidden">
    <div class="absolute -left-32 top-20 h-72 w-72 rounded-full bg-brass/8 blur-3xl" data-parallax="0.1" aria-hidden="true"></div>
    <div class="absolute right-[8%] bottom-10 h-2.5 w-2.5 rounded-full bg-brass/50 floaty hidden lg:block" data-parallax="0.3" aria-hidden="true"></div>
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28 relative">
      <div class="max-w-2xl reveal">
        <span class="eyebrow text-brass-deep">Why Angel</span>
        <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3 text-balance">
          Four good reasons <span class="text-gold">Islington</span> keeps our number.
        </h2>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 gap-5" data-stagger>
        {reasons.map((r) => (
          <div data-tilt="4" class="group relative rounded-3xl border border-line bg-paper/80 backdrop-blur-sm p-7 sm:p-9 shadow-soft hover:shadow-lift transition-shadow overflow-hidden">
            <span class="absolute -right-3 -top-5 font-display text-[7rem] leading-none text-brass/10 select-none tilt-inner">{r.n}</span>
            <span class="relative font-display text-3xl text-gold tilt-inner">{r.n}</span>
            <h3 class="relative font-display text-2xl text-green mt-3 tilt-inner">{r.title}</h3>
            <p class="relative mt-3 text-ink-soft leading-relaxed">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE HUBS -->
  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
      <div class="flex flex-wrap items-end justify-between gap-6 reveal">
        <div class="max-w-xl">
          <span class="eyebrow text-brass-deep">What we do</span>
          <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">
            Three trades, one family firm.
          </h2>
        </div>
        <a href="/services" class="btn btn-ghost">All services</a>
      </div>
      <div class="mt-12 grid lg:grid-cols-3 gap-5" data-stagger>
        {serviceHubs.map((h) => (
          <a href={`/services/${h.slug}`} data-tilt="5" class="group flex flex-col rounded-3xl border border-line bg-paper p-7 shadow-soft hover:border-green/40 hover:shadow-float transition-all">
            <div class="flex items-center justify-between tilt-inner">
              <span class="grid h-12 w-12 place-items-center rounded-2xl bg-green text-cream shadow-soft group-hover:scale-110 transition-transform">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={hubIcon[h.slug]} />
              </span>
              <span class="text-[0.74rem] font-semibold uppercase tracking-wider text-brass-deep">{h.tag}</span>
            </div>
            <h3 class="font-display text-2xl text-green mt-6 tilt-inner">{h.title}</h3>
            <p class="mt-3 text-ink-soft leading-relaxed flex-1">{h.blurb}</p>
            <ul class="mt-5 space-y-1.5">
              {h.services.slice(0, 4).map((s) => (
                <li class="text-[0.88rem] text-ink-soft flex gap-2"><span class="text-brass">›</span>{s.title}</li>
              ))}
            </ul>
            <span class="mt-6 inline-flex items-center gap-1.5 text-green font-semibold text-[0.9rem] group-hover:gap-2.5 transition-all">
              Explore {h.title.toLowerCase()}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOUR PROPERTY ERAS -->
  <section class="relative mesh-green grain text-cream overflow-hidden">
    <svg class="divider-top text-cream" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true"><path fill="currentColor" d="M0 60V30C240 6 480 0 720 12s480 30 720 6v42z"/></svg>
    <div class="absolute inset-0 blueprint opacity-[0.18]" data-parallax="0.05" aria-hidden="true"></div>
    <div class="absolute -right-24 top-1/4 h-80 w-80 rounded-full bg-brass/15 blur-3xl floaty" data-parallax="0.12" aria-hidden="true"></div>
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-24 sm:py-32 relative">
      <div class="max-w-2xl reveal">
        <span class="eyebrow text-brass-soft">The differentiator</span>
        <h2 class="font-display text-4xl sm:text-5xl leading-[1.05] mt-3 text-balance">
          Four property eras, one specialist who <span class="text-brass-soft italic">knows them.</span>
        </h2>
        <p class="mt-4 text-cream/70 leading-relaxed">
          Islington and Clerkenwell hold central London's densest run of period housing. Each era
          plumbs differently - here's what yours typically involves.
        </p>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 xl:grid-cols-4 gap-4" data-stagger>
        {hubEras.map((e, i) => (
          <a href={`/period-property/${e.slug}`} data-tilt="6" class="group relative rounded-3xl glass-dark p-6 hover:border-brass/50 transition-all overflow-hidden">
            <span class="absolute right-4 top-3 font-display text-6xl text-brass/15 select-none">{String(i + 1).padStart(2, "0")}</span>
            <div class="relative flex items-baseline justify-between tilt-inner">
              <h3 class="font-display text-2xl text-cream">{e.name}</h3>
              <span class="text-[0.78rem] text-brass-soft font-medium">{e.years}</span>
            </div>
            <p class="relative text-brass-soft text-[0.92rem] mt-1 italic tilt-inner">{e.hero}</p>
            <p class="relative mt-3 text-cream/65 text-[0.88rem] leading-relaxed">{e.considerations[0]}</p>
            <span class="relative mt-5 inline-flex items-center gap-1.5 text-cream font-medium text-[0.88rem] group-hover:gap-2.5 transition-all">
              {e.name} plumbing
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
      </div>
      <div class="mt-10 reveal">
        <a href="/period-property" class="btn btn-brass" data-magnetic="0.3">See our period-property work</a>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
      <div class="max-w-2xl reveal">
        <span class="eyebrow text-brass-deep">Three generations</span>
        <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">
          Forty years in one square mile.
        </h2>
      </div>
      <ol class="mt-14 relative">
        <div class="absolute left-[7px] sm:left-1/2 top-2 bottom-2 w-px bg-line sm:-translate-x-1/2" aria-hidden="true"></div>
        {timeline.map((t, i) => (
          <li class={`reveal relative pl-9 sm:pl-0 sm:grid sm:grid-cols-2 sm:gap-12 pb-12 last:pb-0 ${i % 2 ? "" : ""}`}>
            <span class="absolute left-0 sm:left-1/2 top-1.5 h-3.5 w-3.5 rounded-full bg-brass ring-4 ring-cream sm:-translate-x-1/2" aria-hidden="true"></span>
            <div class={i % 2 === 0 ? "sm:text-right sm:pr-12" : "sm:col-start-2 sm:pl-12"}>
              <span class="font-display text-3xl text-brass">{t.year}</span>
              <h3 class="font-display text-2xl text-green mt-1">{t.title}</h3>
              <p class="mt-2 text-ink-soft leading-relaxed">{t.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- AREAS -->
  <section class="bg-cream-deep">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
      <div class="flex flex-wrap items-end justify-between gap-6 reveal">
        <div class="max-w-xl">
          <span class="eyebrow text-brass-deep">Ten postcodes covered</span>
          <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">From our door to yours.</h2>
          <p class="mt-4 text-ink-soft leading-relaxed">
            Based at 177 Goswell Road on the Islington/City border - minutes from the period streets
            we know best, and across North London for everything else.
          </p>
        </div>
        <a href="/areas" class="btn btn-ghost">All areas</a>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-stagger>
        {primaryAreas.map((a) => (
          <a href={`/areas/${a.slug}`} data-tilt="4" class="group rounded-3xl border border-line bg-paper p-6 shadow-soft hover:border-green/40 hover:shadow-lift transition-all">
            <div class="flex items-baseline justify-between tilt-inner">
              <h3 class="font-display text-xl text-green group-hover:text-brass-deep transition-colors">{a.name}</h3>
              <span class="text-[0.78rem] font-semibold text-brass-deep">{a.postcode}</span>
            </div>
            <p class="mt-2 text-[0.9rem] text-ink-soft leading-relaxed">{a.blurb}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BUYER TYPES -->
  <section class="relative mesh-cream overflow-hidden">
    <div class="absolute right-[-6%] top-10 h-64 w-64 rounded-full bg-green/5 blur-3xl" data-parallax="0.12" aria-hidden="true"></div>
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28 relative">
      <div class="max-w-2xl reveal">
        <span class="eyebrow text-brass-deep">Are you a…</span>
        <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">However you live here, <span class="text-gold">we can help.</span></h2>
      </div>
      <div class="mt-12 grid lg:grid-cols-3 gap-5" data-stagger>
        {buyerTypes.map((b) => (
          <a href={`/${b.slug}`} data-tilt="5" class="group flex flex-col rounded-3xl border border-line bg-paper p-8 shadow-soft hover:border-green/40 hover:shadow-float transition-all">
            <span class="text-[0.74rem] font-semibold uppercase tracking-wider text-brass-deep tilt-inner">{b.tag}</span>
            <h3 class="font-display text-2xl text-green mt-3 tilt-inner">{b.title}</h3>
            <p class="mt-3 text-ink-soft leading-relaxed flex-1">{b.blurb}</p>
            <span class="mt-6 inline-flex items-center gap-1.5 text-green font-semibold text-[0.9rem] group-hover:gap-2.5 transition-all">
              Learn more
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CP12 -->
  <section class="bg-cream-deep">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-24">
      <div class="reveal"><Cp12Tool /></div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
      <div class="flex flex-wrap items-end justify-between gap-6 reveal">
        <div class="max-w-xl">
          <span class="eyebrow text-brass-deep">In their words</span>
          <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">Rated {business.reviewRating} by Islington.</h2>
          <p class="mt-4 text-ink-soft">From {business.reviewCount} verified Checkatrade reviews.</p>
        </div>
        <a href="/reviews" class="btn btn-ghost">Read all reviews</a>
      </div>
      <div class="mt-12 grid lg:grid-cols-3 gap-5" data-stagger>
        {reviews.map((r) => (
          <figure data-tilt="4" class="group relative flex flex-col rounded-3xl border border-line bg-paper p-7 shadow-soft hover:shadow-lift transition-shadow overflow-hidden">
            <span class="absolute -right-1 -top-6 font-display text-[8rem] leading-none text-brass/10 select-none" aria-hidden="true">”</span>
            <div class="relative flex gap-0.5 text-brass" aria-label={`${r.rating} out of 10`}>
              {Array.from({ length: 5 }).map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 3 6.9 7.5.6-5.7 4.9 1.8 7.3L12 17.8 5.1 21.7l1.8-7.3L1.2 9.5 8.7 8.9 12 2Z"/></svg>
              ))}
            </div>
            <blockquote class="relative mt-4 text-ink-soft leading-relaxed flex-1 text-[0.95rem]">"{r.text}"</blockquote>
            <figcaption class="relative mt-5 pt-5 border-t border-line flex items-center justify-between">
              <span class="font-semibold text-ink">{r.name} <span class="text-ink-soft font-normal">· {r.place}</span></span>
              <span class="text-[0.76rem] text-brass-deep font-medium">{r.source}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <Marquee items={marqueeItems} />

  <!-- CLOSING CTA -->
  <ClosingCTA />

  <!-- CONTACT -->
  <ContactSection />
</Base>
