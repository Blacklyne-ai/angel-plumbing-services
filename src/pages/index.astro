---
import Base from "../layouts/Base.astro";
import TerraceFacade from "../components/art/TerraceFacade.astro";
import PeriodWizard from "../components/PeriodWizard.astro";
import TrustStrip from "../components/TrustStrip.astro";
import Marquee from "../components/Marquee.astro";
import Cp12Tool from "../components/Cp12Tool.astro";
import ClosingCTA from "../components/ClosingCTA.astro";
import ContactSection from "../components/ContactSection.astro";
import {
  business, serviceHubs, eras, areas, buyerTypes, reasons, timeline, reviews,
} from "../data/site";

const hubEras = eras.filter((e) => e.inHub);
const primaryAreas = areas.filter((a) => a.primary);
const marqueeItems = [
  "Islington", "Clerkenwell", "Highbury", "Canonbury", "Barnsbury", "Angel",
  "Holloway", "Finsbury", "King's Cross", "Hackney", "Camden", "Period property specialists",
];
const hubIcon: Record<string, string> = {
  plumbing: `<path d="M8 21h8M12 21v-6M5 4h6v4a3 3 0 0 1-6 0V4Z"/><path d="M11 6h4a4 4 0 0 1 4 4v2"/>`,
  heating: `<path d="M12 3c0 4-5 5-5 9a5 5 0 0 0 10 0c0-2-1-3-2-4 .2 2-1 3-2 3 .5-3-1-6-1-8Z"/>`,
  "gas-safety": `<path d="M12 3 5 6v5c0 4 3 7 7 9 4-2 7-5 7-9V6l-7-3Z"/><path d="m9 12 2 2 4-4"/>`,
};
---
<Base
  title="Period-Property Plumbers in Islington & Clerkenwell"
  description="Angel Plumbing Services - family-run plumbing & heating in Islington and Clerkenwell since the 1980s. Period-property specialists, Gas Safe registered, APHC members. 24-hour emergency. Call 020 7251 3418."
  path="/"
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-cream pt-28 sm:pt-32">
    <div class="absolute inset-0 dot-grid opacity-40" aria-hidden="true"></div>
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 relative">
      <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-10 lg:gap-8 items-end pb-16 sm:pb-20">
        <div class="pt-6 sm:pt-10">
          <p class="eyebrow text-brass-deep flex flex-wrap items-center gap-x-2 gap-y-1">
            <span>Clerkenwell</span><span class="text-line">·</span>
            <span>Islington</span><span class="text-line">·</span>
            <span>Gas Safe registered</span><span class="text-line">·</span>
            <span>APHC member</span>
          </p>
          <h1 class="font-display text-[2.7rem] sm:text-6xl xl:text-7xl text-green leading-[1.02] tracking-tight mt-5">
            Period-property plumbing, family-run.
            <span class="block italic font-bold mt-1">Islington &amp; Clerkenwell since the 1980s.</span>
          </h1>
          <p class="mt-6 text-lg text-ink-soft leading-relaxed max-w-xl">
            Forty years on Goswell Road, looking after the Georgian and Victorian homes that surround
            us. Bathrooms, heating, drainage and gas safety - done with respect for the building
            they sit in, and a 24-hour line when it can't wait.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#wizard" class="btn btn-primary">Find your property's plumbing</a>
            <a href={`tel:${business.phoneHref}`} class="btn btn-ghost">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2Z"/></svg>
              {business.phoneDisplay}
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="relative aspect-[3/4] sm:aspect-[4/5] lg:aspect-[3/4] overflow-hidden rounded-[2rem] border border-line shadow-lift bg-cream-deep">
            <TerraceFacade class="absolute inset-0 h-full w-full" />
          </div>
          <div class="absolute -left-3 sm:-left-6 bottom-8 rounded-2xl border border-line bg-paper/95 backdrop-blur px-5 py-3.5 shadow-soft">
            <p class="font-display text-2xl text-green leading-none">Est. 1980s</p>
            <p class="text-[0.74rem] font-semibold uppercase tracking-wider text-brass-deep mt-1">Goswell Road · EC1</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT BAND -->
  <section class="bg-green text-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-8">
      <dl class="grid grid-cols-2 lg:grid-cols-4 gap-y-6 gap-x-4 divide-line/0">
        {[
          ["Since the 1980s", "Family-run in Islington"],
          ["Gas Safe", "Registered for gas work"],
          ["APHC", "Vetted trade member"],
          ["24-hour", "Emergency cover"],
        ].map(([v, l]) => (
          <div class="text-center lg:text-left lg:px-2">
            <dt class="font-display text-2xl sm:text-3xl text-cream">{v}</dt>
            <dd class="text-[0.82rem] text-cream/65 mt-1">{l}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <TrustStrip />

  <!-- WIZARD -->
  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-24">
      <div class="reveal">
        <PeriodWizard />
      </div>
    </div>
  </section>

  <!-- FOUR GOOD REASONS -->
  <section class="bg-cream-deep">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
      <div class="max-w-2xl reveal">
        <span class="eyebrow text-brass-deep">Why Angel</span>
        <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">
          Four good reasons<br />Islington keeps our number.
        </h2>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 gap-5">
        {reasons.map((r) => (
          <div class="reveal rounded-3xl border border-line bg-paper p-7 sm:p-8 hover:shadow-soft transition-shadow">
            <span class="font-display text-3xl text-brass">{r.n}</span>
            <h3 class="font-display text-2xl text-green mt-3">{r.title}</h3>
            <p class="mt-3 text-ink-soft leading-relaxed">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE HUBS -->
  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
      <div class="flex flex-wrap items-end justify-between gap-6 reveal">
        <div class="max-w-xl">
          <span class="eyebrow text-brass-deep">What we do</span>
          <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">
            Three trades, one family firm.
          </h2>
        </div>
        <a href="/services" class="btn btn-ghost">All services</a>
      </div>
      <div class="mt-12 grid lg:grid-cols-3 gap-5">
        {serviceHubs.map((h) => (
          <a href={`/services/${h.slug}`} class="reveal group flex flex-col rounded-3xl border border-line bg-paper p-7 hover:border-green/40 hover:shadow-lift transition-all">
            <div class="flex items-center justify-between">
              <span class="grid h-12 w-12 place-items-center rounded-2xl bg-green/8 text-green">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={hubIcon[h.slug]} />
              </span>
              <span class="text-[0.74rem] font-semibold uppercase tracking-wider text-brass-deep">{h.tag}</span>
            </div>
            <h3 class="font-display text-2xl text-green mt-6">{h.title}</h3>
            <p class="mt-3 text-ink-soft leading-relaxed flex-1">{h.blurb}</p>
            <ul class="mt-5 space-y-1.5">
              {h.services.slice(0, 4).map((s) => (
                <li class="text-[0.88rem] text-ink-soft flex gap-2"><span class="text-brass">›</span>{s.title}</li>
              ))}
            </ul>
            <span class="mt-6 inline-flex items-center gap-1.5 text-green font-semibold text-[0.9rem] group-hover:gap-2.5 transition-all">
              Explore {h.title.toLowerCase()}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOUR PROPERTY ERAS -->
  <section class="bg-green-deep text-cream relative overflow-hidden">
    <div class="absolute inset-0 dot-grid opacity-[0.06]" aria-hidden="true"></div>
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28 relative">
      <div class="max-w-2xl reveal">
        <span class="eyebrow text-brass-soft">The differentiator</span>
        <h2 class="font-display text-4xl sm:text-5xl leading-[1.05] mt-3">
          Four property eras,<br />one specialist who knows them.
        </h2>
        <p class="mt-4 text-cream/70 leading-relaxed">
          Islington and Clerkenwell hold central London's densest run of period housing. Each era
          plumbs differently - here's what yours typically involves.
        </p>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 xl:grid-cols-4 gap-4">
        {hubEras.map((e) => (
          <a href={`/period-property/${e.slug}`} class="reveal group rounded-3xl border border-cream/12 bg-cream/[0.04] p-6 hover:bg-cream/[0.08] hover:border-brass/40 transition-all">
            <div class="flex items-baseline justify-between">
              <h3 class="font-display text-2xl text-cream">{e.name}</h3>
              <span class="text-[0.78rem] text-brass-soft font-medium">{e.years}</span>
            </div>
            <p class="text-brass-soft text-[0.92rem] mt-1 italic">{e.hero}</p>
            <p class="mt-3 text-cream/65 text-[0.88rem] leading-relaxed">{e.considerations[0]}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-cream font-medium text-[0.88rem] group-hover:gap-2.5 transition-all">
              {e.name} plumbing
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
      </div>
      <div class="mt-8">
        <a href="/period-property" class="btn btn-brass">See our period-property work</a>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
      <div class="max-w-2xl reveal">
        <span class="eyebrow text-brass-deep">Three generations</span>
        <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">
          Forty years in one square mile.
        </h2>
      </div>
      <ol class="mt-14 relative">
        <div class="absolute left-[7px] sm:left-1/2 top-2 bottom-2 w-px bg-line sm:-translate-x-1/2" aria-hidden="true"></div>
        {timeline.map((t, i) => (
          <li class={`reveal relative pl-9 sm:pl-0 sm:grid sm:grid-cols-2 sm:gap-12 pb-12 last:pb-0 ${i % 2 ? "" : ""}`}>
            <span class="absolute left-0 sm:left-1/2 top-1.5 h-3.5 w-3.5 rounded-full bg-brass ring-4 ring-cream sm:-translate-x-1/2" aria-hidden="true"></span>
            <div class={i % 2 === 0 ? "sm:text-right sm:pr-12" : "sm:col-start-2 sm:pl-12"}>
              <span class="font-display text-3xl text-brass">{t.year}</span>
              <h3 class="font-display text-2xl text-green mt-1">{t.title}</h3>
              <p class="mt-2 text-ink-soft leading-relaxed">{t.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- AREAS -->
  <section class="bg-cream-deep">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
      <div class="flex flex-wrap items-end justify-between gap-6 reveal">
        <div class="max-w-xl">
          <span class="eyebrow text-brass-deep">Ten postcodes covered</span>
          <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">From our door to yours.</h2>
          <p class="mt-4 text-ink-soft leading-relaxed">
            Based at 177 Goswell Road on the Islington/City border - minutes from the period streets
            we know best, and across North London for everything else.
          </p>
        </div>
        <a href="/areas" class="btn btn-ghost">All areas</a>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {primaryAreas.map((a) => (
          <a href={`/areas/${a.slug}`} class="reveal group rounded-3xl border border-line bg-paper p-6 hover:border-green/40 hover:shadow-soft transition-all">
            <div class="flex items-baseline justify-between">
              <h3 class="font-display text-xl text-green">{a.name}</h3>
              <span class="text-[0.78rem] font-semibold text-brass-deep">{a.postcode}</span>
            </div>
            <p class="mt-2 text-[0.9rem] text-ink-soft leading-relaxed">{a.blurb}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BUYER TYPES -->
  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
      <div class="max-w-2xl reveal">
        <span class="eyebrow text-brass-deep">Are you a…</span>
        <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">However you live here, we can help.</h2>
      </div>
      <div class="mt-12 grid lg:grid-cols-3 gap-5">
        {buyerTypes.map((b) => (
          <a href={`/${b.slug}`} class="reveal group flex flex-col rounded-3xl border border-line bg-paper p-7 hover:border-green/40 hover:shadow-lift transition-all">
            <span class="text-[0.74rem] font-semibold uppercase tracking-wider text-brass-deep">{b.tag}</span>
            <h3 class="font-display text-2xl text-green mt-3">{b.title}</h3>
            <p class="mt-3 text-ink-soft leading-relaxed flex-1">{b.blurb}</p>
            <span class="mt-6 inline-flex items-center gap-1.5 text-green font-semibold text-[0.9rem] group-hover:gap-2.5 transition-all">
              Learn more
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CP12 -->
  <section class="bg-cream-deep">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-24">
      <div class="reveal"><Cp12Tool /></div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-28">
      <div class="flex flex-wrap items-end justify-between gap-6 reveal">
        <div class="max-w-xl">
          <span class="eyebrow text-brass-deep">In their words</span>
          <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">Rated {business.reviewRating} by Islington.</h2>
          <p class="mt-4 text-ink-soft">From {business.reviewCount} verified Checkatrade reviews.</p>
        </div>
        <a href="/reviews" class="btn btn-ghost">Read all reviews</a>
      </div>
      <div class="mt-12 grid lg:grid-cols-3 gap-5">
        {reviews.map((r) => (
          <figure class="reveal flex flex-col rounded-3xl border border-line bg-paper p-7">
            <div class="flex gap-0.5 text-brass" aria-label={`${r.rating} out of 10`}>
              {Array.from({ length: 5 }).map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 3 6.9 7.5.6-5.7 4.9 1.8 7.3L12 17.8 5.1 21.7l1.8-7.3L1.2 9.5 8.7 8.9 12 2Z"/></svg>
              ))}
            </div>
            <blockquote class="mt-4 text-ink-soft leading-relaxed flex-1 text-[0.95rem]">"{r.text}"</blockquote>
            <figcaption class="mt-5 pt-5 border-t border-line flex items-center justify-between">
              <span class="font-semibold text-ink">{r.name} <span class="text-ink-soft font-normal">· {r.place}</span></span>
              <span class="text-[0.76rem] text-ink-soft">{r.source}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <Marquee items={marqueeItems} />

  <!-- CLOSING CTA -->
  <ClosingCTA />

  <!-- CONTACT -->
  <ContactSection />
</Base>
