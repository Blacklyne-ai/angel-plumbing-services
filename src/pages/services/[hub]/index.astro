---
import Base from "../../../layouts/Base.astro";
import PageHero from "../../../components/PageHero.astro";
import ClosingCTA from "../../../components/ClosingCTA.astro";
import ContactSection from "../../../components/ContactSection.astro";
import { serviceHubs, business } from "../../../data/site";

export function getStaticPaths() {
  return serviceHubs.map((h) => ({ params: { hub: h.slug }, props: { hub: h } }));
}
const { hub } = Astro.props;
const others = serviceHubs.filter((h) => h.slug !== hub.slug);
---
<Base
  title={`${hub.title} Services in Islington & Clerkenwell`}
  description={`${hub.title} from Angel Plumbing Services - ${hub.blurb} Gas Safe registered, family-run since the 1980s. Call ${business.phoneDisplay}.`}
  path={`/services/${hub.slug}`}
>
  <PageHero
    eyebrow={hub.tag}
    title={`${hub.title}, done<br /><span class='italic font-bold'>properly.</span>`}
    lead={hub.blurb}
    crumbs={[{ label: "Home", href: "/" }, { label: "Services", href: "/services" }, { label: hub.title, href: `/services/${hub.slug}` }]}
  />

  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-24">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {hub.services.map((s, i) => (
          <a href={`/services/${hub.slug}/${s.slug}`} class="reveal group flex flex-col rounded-3xl border border-line bg-paper p-7 hover:border-green/40 hover:shadow-lift transition-all">
            <span class="font-display text-3xl text-brass">{String(i + 1).padStart(2, "0")}</span>
            <h2 class="font-display text-2xl text-green mt-3 group-hover:text-brass-deep transition-colors">{s.title}</h2>
            <p class="mt-3 text-ink-soft leading-relaxed flex-1">{s.short}</p>
            <span class="mt-6 inline-flex items-center gap-1.5 text-green font-semibold text-[0.9rem] group-hover:gap-2.5 transition-all">
              Read more
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="mt-16 reveal">
        <p class="eyebrow text-brass-deep mb-5">Other trades</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {others.map((o) => (
            <a href={`/services/${o.slug}`} class="group flex items-center justify-between rounded-2xl border border-line bg-paper px-6 py-5 hover:border-green/40 transition-colors">
              <span class="font-display text-xl text-green">{o.title}</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brass group-hover:translate-x-1 transition-transform" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ClosingCTA />
  <ContactSection />
</Base>
