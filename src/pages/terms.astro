---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import { business } from "../data/site";
---
<Base
  title="Terms of Use"
  description="The terms governing your use of the Angel Plumbing Services website."
  path="/terms"
>
  <PageHero eyebrow="Legal" title="Terms of Use"
    crumbs={[{ label: "Home", href: "/" }, { label: "Terms", href: "/terms" }]} />

  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-16 sm:py-20">
      <div class="prose-legal">
        <p>These terms govern your use of the {business.legalName} website. By using this website you
          accept these terms.</p>

        <h2>About us</h2>
        <p>This website is operated by {business.legalName}, a company registered in England and Wales
          (company number {business.companyNumber}), registered office {business.address.line1},
          {business.address.line2}, {business.address.city} {business.address.postcode}.</p>

        <h2>Information on this site</h2>
        <p>The content of this website is provided for general information about our services. The
          guidance in our period-property tool and other on-site tools is indicative only and is not a
          substitute for a site visit, a formal quotation, or professional and regulatory advice. Timelines,
          considerations and any listed-building guidance are general and will vary by property. Always
          confirm requirements - including listed-building consent - with the relevant authority before
          starting work.</p>

        <h2>No quote or contract</h2>
        <p>Nothing on this website constitutes a quotation or a binding offer. Any work we carry out is
          subject to a separate agreement and quotation provided to you directly.</p>

        <h2>Gas safety</h2>
        <p>Gas work is carried out by Gas Safe registered engineers. In a gas emergency, leave the
          property and call the National Gas Emergency line on 0800 111 999 immediately.</p>

        <h2>Intellectual property</h2>
        <p>The design, text and graphics on this website are owned by or licensed to {business.legalName}
          and may not be reproduced without permission.</p>

        <h2>Liability</h2>
        <p>We take reasonable care to keep this website accurate and available, but we do not guarantee it
          will be error-free or uninterrupted. To the extent permitted by law, we are not liable for any
          loss arising from reliance on the website's content. Nothing in these terms limits liability that
          cannot be limited by law.</p>

        <h2>External links</h2>
        <p>This website may link to third-party sites. We are not responsible for their content or
          practices.</p>

        <h2>Governing law</h2>
        <p>These terms are governed by the law of England and Wales, and the courts of England and Wales
          have exclusive jurisdiction.</p>

        <h2>Contact</h2>
        <p>Questions about these terms? Email <a href={`mailto:${business.email}`}>{business.email}</a> or
          call {business.phoneDisplay}.</p>
      </div>
    </div>
  </section>
</Base>
