---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import ContactSection from "../components/ContactSection.astro";
import { business } from "../data/site";
---
<Base
  title="Contact Angel Plumbing Services - 020 7251 3418"
  description="Contact Angel Plumbing Services in Clerkenwell, Islington. Call 020 7251 3418, email Info@angelplumbing.london, or send an enquiry. 177 Goswell Road, London EC1V 7HJ. 24-hour emergency cover across North London."
  path="/contact"
>
  <PageHero
    eyebrow="Get in touch"
    title="Let's talk about<br /><span class='italic font-bold'>your property.</span>"
    lead="Booking a site visit, chasing a quote, or dealing with an emergency - reach us however suits. We cover Islington, Clerkenwell and across North London."
    crumbs={[{ label: "Home", href: "/" }, { label: "Contact", href: "/contact" }]}
  />

  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 pt-16 sm:pt-20 -mb-8">
      <div class="grid sm:grid-cols-3 gap-4">
        <a href={`tel:${business.phoneHref}`} class="reveal rounded-3xl border border-line bg-paper p-7 hover:border-green/40 hover:shadow-soft transition-all">
          <span class="grid h-11 w-11 place-items-center rounded-full bg-green text-cream"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2Z"/></svg></span>
          <p class="eyebrow text-brass-deep mt-4">Call (incl. 24-hr)</p>
          <p class="font-display text-2xl text-green mt-1">{business.phoneDisplay}</p>
        </a>
        <a href={`mailto:${business.email}`} class="reveal rounded-3xl border border-line bg-paper p-7 hover:border-green/40 hover:shadow-soft transition-all">
          <span class="grid h-11 w-11 place-items-center rounded-full bg-green text-cream"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="m3 8 9 5 9-5"/></svg></span>
          <p class="eyebrow text-brass-deep mt-4">Email</p>
          <p class="font-display text-xl text-green mt-1 break-all">{business.email}</p>
        </a>
        <div class="reveal rounded-3xl border border-line bg-paper p-7">
          <span class="grid h-11 w-11 place-items-center rounded-full bg-green text-cream"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></span>
          <p class="eyebrow text-brass-deep mt-4">Visit</p>
          <p class="text-ink mt-1 leading-snug">{business.address.line1}, {business.address.line2}<br />{business.address.city} {business.address.postcode}</p>
        </div>
      </div>
    </div>
  </section>

  <ContactSection heading="Send us an enquiry" />
</Base>
