---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import Cp12Tool from "../components/Cp12Tool.astro";
import ClosingCTA from "../components/ClosingCTA.astro";
import ContactSection from "../components/ContactSection.astro";
import { business } from "../data/site";
import heroImg from "../assets/photos/hero-townhouses.jpg";

const offer = [
  ["Landlord CP12 certificates", "Your annual Gas Safety Record for each let property, issued promptly for your records and your tenants.", "/services/gas-safety/landlord-cp12"],
  ["Free renewal reminders", "We'll remind you around 30 days before a certificate is due, so a renewal never slips.", "/cp12-reminder"],
  ["Repairs &amp; maintenance", "Boilers, heating, leaks and plumbing across your portfolio, from one trusted family firm.", "/services"],
  ["Boiler servicing", "Annual servicing to keep appliances safe, efficient and within warranty.", "/services/heating/boiler-repair"],
];
---
<Base
  title="Plumber for Landlords - CP12 Certificates in Islington"
  description="Plumbing, heating and CP12 Landlord Gas Safety Certificates for landlords across Islington, Clerkenwell and North London. Free renewal reminders, portfolio landlords welcome. Family-run, Gas Safe registered. Call 020 7251 3418."
  path="/for-landlords"
>
  <PageHero
    eyebrow="For landlords"
    title="One family firm for<br /><span class='italic font-bold'>your whole portfolio.</span>"
    lead="CP12 certificates, repairs and boiler work across Islington and Clerkenwell rentals - with a free reminder so you never miss a renewal, and a single number to call."
    crumbs={[{ label: "Home", href: "/" }, { label: "For landlords", href: "/for-landlords" }]}
    image={heroImg}
    imageAlt="A row of red-brick Victorian townhouses in London"
  />

  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-24">
      <div class="grid sm:grid-cols-2 gap-5">
        {offer.map(([t, b, href]) => (
          <a href={href} class="reveal group flex flex-col rounded-3xl border border-line bg-paper p-7 hover:border-green/40 hover:shadow-lift transition-all">
            <h2 class="font-display text-2xl text-green group-hover:text-brass-deep transition-colors" set:html={t} />
            <p class="mt-3 text-ink-soft leading-relaxed flex-1" set:html={b} />
            <span class="mt-5 inline-flex items-center gap-1.5 text-green font-semibold text-[0.88rem] group-hover:gap-2.5 transition-all">
              Learn more
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-cream-deep">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-16 sm:py-20">
      <div class="reveal"><Cp12Tool /></div>
    </div>
  </section>

  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-24">
      <div class="max-w-3xl reveal">
        <span class="eyebrow text-brass-deep">Why landlords stay with us</span>
        <h2 class="font-display text-4xl sm:text-5xl text-green leading-[1.05] mt-3">Compliance you don't have to chase.</h2>
        <p class="mt-5 text-ink-soft leading-relaxed">
          Clerkenwell and Islington have one of London's densest rental markets, and keeping every
          property compliant is a job in itself. We make it simple: one family firm that knows your
          buildings, issues your certificates on time, reminds you before they lapse, and handles the
          repairs in between. No call centre, no being passed around - just the same people, year after year.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">Talk to us about your portfolio</a>
          <a href={`tel:${business.phoneHref}`} class="btn btn-ghost">{business.phoneDisplay}</a>
        </div>
      </div>
    </div>
  </section>

  <ClosingCTA heading="Landlord in Islington or Clerkenwell?" sub="Book your CP12, set a free reminder, or hand us the whole portfolio. Family-run since the 1980s." />
  <ContactSection heading="Tell us about your properties" />
</Base>
