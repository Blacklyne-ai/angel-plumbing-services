---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import ClosingCTA from "../../components/ClosingCTA.astro";
import ContactSection from "../../components/ContactSection.astro";
import { areas, extraAreaNames, business } from "../../data/site";
import heroImg from "../../assets/photos/terrace-row.jpg";
const primary = areas.filter((a) => a.primary);
const secondary = areas.filter((a) => !a.primary);
---
<Base
  title="Areas We Cover - Islington, Clerkenwell & North London"
  description="Angel Plumbing covers Islington, Clerkenwell, Highbury, Canonbury, Barnsbury, Angel, King's Cross and across North London from our base at 177 Goswell Road, EC1. Family-run period-property plumbers since the 1980s."
  path="/areas"
>
  <PageHero
    eyebrow="Ten postcodes covered"
    title="From our door<br /><span class='italic font-bold'>to yours.</span>"
    lead="Based at 177 Goswell Road on the Islington/City border - minutes from the period streets we know best, and across North London for everything else."
    crumbs={[{ label: "Home", href: "/" }, { label: "Areas", href: "/areas" }]}
    image={heroImg}
    imageAlt="A row of red-brick Victorian mansion blocks in London"
  />

  <section class="bg-cream">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-20 sm:py-24">
      <h2 class="font-display text-3xl text-green mb-8 reveal">Our core patch</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {primary.map((a) => (
          <a href={`/areas/${a.slug}`} class="reveal group flex flex-col rounded-3xl border border-line bg-paper p-7 hover:border-green/40 hover:shadow-lift transition-all">
            <div class="flex items-baseline justify-between">
              <h3 class="font-display text-2xl text-green group-hover:text-brass-deep transition-colors">{a.name}</h3>
              <span class="text-[0.78rem] font-semibold text-brass-deep">{a.postcode}</span>
            </div>
            <p class="mt-3 text-[0.92rem] text-ink-soft leading-relaxed flex-1">{a.blurb}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-green font-semibold text-[0.88rem] group-hover:gap-2.5 transition-all">
              {a.name} plumbers
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
      </div>

      <h2 class="font-display text-3xl text-green mt-16 mb-8 reveal">Also covered</h2>
      <div class="grid sm:grid-cols-2 gap-4 mb-8">
        {secondary.map((a) => (
          <a href={`/areas/${a.slug}`} class="reveal group flex items-center justify-between rounded-2xl border border-line bg-paper px-6 py-5 hover:border-green/40 transition-colors">
            <span><span class="font-display text-xl text-green">{a.name}</span> <span class="text-[0.78rem] text-brass-deep font-semibold ml-1">{a.postcode}</span></span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brass group-hover:translate-x-1 transition-transform" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        ))}
      </div>
      <div class="reveal rounded-3xl border border-line bg-cream-deep p-7">
        <p class="text-ink-soft leading-relaxed">
          We also cover <span class="text-ink font-medium">{extraAreaNames.join(", ")}</span> and the
          wider North London area. Not sure if we reach you? Call <a href={`tel:${business.phoneHref}`} class="text-brass-deep underline hover:text-green">{business.phoneDisplay}</a> and we'll let you know.
        </p>
      </div>
    </div>
  </section>

  <ClosingCTA />
  <ContactSection />
</Base>
